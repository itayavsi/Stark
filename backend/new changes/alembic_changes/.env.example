# Active DB target: neon (default) or local
DB_TARGET=neon

# Neon / primary Postgres connection string
DATABASE_URL=postgresql://<role>:<password>@<your-neon-endpoint-pooler>/<database>?sslmode=require

# Optional local Postgres URL used when DB_TARGET=local
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gis_app
